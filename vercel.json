{
  "redirects": [
    {
      "source": "/brand",
      "destination": "/brand/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "contact.portfolio.sc" }],
      "destination": "/contact",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/formation",
      "destination": "https://formation-portfoliostudios.vercel.app/formation"
    },
    {
      "source": "/formation/:path*",
      "destination": "https://formation-portfoliostudios.vercel.app/formation/:path*"
    }
  ]
}
